# Copy this file to ".env" and fill in your key(s), OR export them in your shell.
# Each reputation source has its own key; a source with no key is simply skipped
# in the multi-source fan-out, so you can set only the ones you want.
#
# VirusTotal (free; signup): https://www.virustotal.com/gui/my-apikey
# Free tier: ~4 lookups/min, 500/day -- plenty for local testing.
VT_API_KEY=your_virustotal_api_key_here
#
# URLhaus / abuse.ch (free Auth-Key, mandatory since 2025-06-30): https://auth.abuse.ch/
# Used by lookup_indicator for url/ip/domain reputation alongside VirusTotal.
URLHAUS_API_KEY=your_urlhaus_auth_key_here
#
# urlscan.io (free key): https://urlscan.io/user/apikey/
# Used by lookup_indicator for url/ip/domain reputation (searches existing scans).
URLSCAN_API_KEY=your_urlscan_api_key_here
#
# NOTE: .env is gitignored. Never commit a real key.
