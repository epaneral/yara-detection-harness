# Copy this file to ".env" and fill in your key, OR export VT_API_KEY in your shell.
# Get a free VirusTotal API key (signup required): https://www.virustotal.com/gui/my-apikey
# Free tier: ~4 lookups/min, 500/day -- plenty for local testing.
#
# NOTE: .env is gitignored. Never commit a real key.
VT_API_KEY=your_virustotal_api_key_here
